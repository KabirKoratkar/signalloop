# Server-only OpenAI configuration. Never expose this key to browser code.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-luna

# Keep paid inference off by default. Enable only in a trusted local environment.
OPENAI_LIVE_ENABLED=false

# Zero uses public, read-only capability discovery. It never pays for or invokes
# a capability from the application route.
ZERO_LIVE_ENABLED=true
